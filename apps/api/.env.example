# Stellar
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Soroban contract addresses (set after deploying contracts)
SOROBAN_CONTRACT_PROCEEDS_DISTRIBUTION=
SOROBAN_CONTRACT_REDEMPTION=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/stellarcrop

# Auth
JWT_SECRET=
JWT_EXPIRY=7d

# KYC providers (optional)
SUMSUB_SECRET_KEY=
SUMSUB_APP_TOKEN=
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=

# File storage (for warehouse receipt documents)
STORAGE_DRIVER=local

# App
PORT=3000
